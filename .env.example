# Copy to .env in this directory (repo root) or modules/llm/.env
# Do not commit .env — it is gitignored.

# Kaggle API token from https://www.kaggle.com/settings → API → Generate New Token
KAGGLE_API_TOKEN=

# Legacy alternative (optional; use instead of KAGGLE_API_TOKEN)
# KAGGLE_USERNAME=
# KAGGLE_KEY=
